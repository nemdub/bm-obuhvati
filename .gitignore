# Raw + derived data (large; not version controlled). Glob the CONTENTS (not the dir) so the
# one committed exception below can be re-included — gitignore can't re-add a file whose
# parent directory is itself excluded.
data/*
# ...except the Nominatim (OSM) fallback cache: small, committed so a recompute never
# re-queries OpenStreetMap and coverage stays reproducible across checkouts / CI.
!data/osm_cache.json
pipeline/artifacts/

# Python
.venv/
__pycache__/
*.pyc
.mypy_cache/
.ruff_cache/

# Node / Worker
node_modules/
worker/node_modules/
worker/.wrangler/
worker/dist/
.dev.vars

# OS
.DS_Store
.wrangler
.claude
.idea
